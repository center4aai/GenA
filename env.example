# MongoDB
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_HOST=
MONGO_PORT=
MONGO_DB_NAME=
MAX_MESSAGES_HISTORY=

# Milvus
MILVUS_HOST=
MILVUS_PORT=

# API

LLM_MODEL_NAME=
LLM_URL_MODEL=
LLM_API_KEY=

API_GEN_QUE_URL=http://agent-api:8790/process_prompt/

AGENT_API_URL = http://agent-api:8790

# Embedding
TEI_MODEL_NAME=
TEI_URL_EMBEDDER=
TEI_API_KEY=

API_DATASET_URL=http://dataset-api:8789

# LLM
MAX_LEN_USER_PROMPT=
API_CHANKS_URL=
CHUNKS_DIR=./chunks
MODEL_NAME=

# GigaChat / Yandex (несекретные дефолты см. config/llm_defaults.env — один источник для gen_env и приложений)
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=
GIGACHAT_MODEL=

YANDEX_CLOUD_API_KEY=
YANDEX_CLOUD_FOLDER=
YANDEX_CLOUD_MODEL=

LLM_PROVIDER=

# Dataset API auth (required in production — no defaults)
EXPERT_USERNAME=admin
EXPERT_PASSWORD=
USER_USERNAME=user
USER_PASSWORD=

# Task worker → dataset API auth (required in production)
DATASET_API_USER=expert
DATASET_API_PASS=

# ArgoCD model discovery (optional; leave empty to use KNOWN_SERVICES / MODEL_ENDPOINTS)
ARGOCD_URL=
ARGOCD_USERNAME=
ARGOCD_PASSWORD=
TRAEFIK_HOST=
TRAEFIK_PORT=27373

# Additional model endpoints (JSON array), example:
# MODEL_ENDPOINTS=[{"id":"qwen3-27b","name":"Qwen3.5 27B","base_url":"http://localhost:27373/llamacpp-qwen3-5-27b-ws5/v1","model_name":"Qwen3.5-27B-Q8_0.gguf","api_key":"none"}]
# With provider: MODEL_ENDPOINTS=[{"id":"gigachat-2","name":"GigaChat-2","provider":"gigachat","base_url":"","model_name":"GigaChat-2","api_key":"<credentials>","extra":{"scope":"GIGACHAT_API_PERS"}}]
MODEL_ENDPOINTS=

# Task worker (LLM call timeout; optional)
WORKER_AGENT_TIMEOUT=600
WORKER_AGENT_MAX_RETRIES=2

# Web (host port for gena_frontend HTTPS SPA; defaults to 27371 if unset)
WEB_PORT=27371
STREAMLIT_PORT=27372

# Same-origin API proxy paths baked into the SPA at build time
VITE_DATASET_API_URL=/api/dataset
VITE_AGENT_API_URL=/api/agent
VITE_CHUNKER_URL=/api/chunker

#DOCKER
GENA_NET=gena_net

AGENT_API_CONTAINER_NAME=agent-api
GENA_WEB_CONTAINER_NAME=gena_web
GENA_FRONTEND_CONTAINER_NAME=gena_frontend
DATASET_API_CONTAINER_NAME=dataset-api
TASK_WORKER_CONTAINER_NAME=task_worker
GENA_CHUNKER_CONTAINER_NAME=gena-chunker
RUADAPT_QWEN_SERVER_CONTAINER_NAME=quadapt_qwen_server