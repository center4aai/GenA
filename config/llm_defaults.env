# Общие несекретные параметры для GigaChat и YandexGPT.
# Единый источник: подхватывается gen_env.sh, agent_api/config.py, chunker (через .env из gen_env или этот файл в образе).

GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-2
YANDEX_CLOUD_MODEL=yandexgpt-5-lite/latest
LLM_PROVIDER=openai

# ── Chunker: semantic sub-chunking (chonkie) ──
# CHUNKER_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# CHUNKER_SEMANTIC_CHUNK_SIZE=512
# CHUNKER_SEMANTIC_THRESHOLD=0.5
# CHUNKER_SEMANTIC_SPLIT_CHARS=2000
# CHUNKER_MIN_MERGE_CHARS=300
