{
  "patterns": [
    {
      "name": "Комментарии ГАРАНТ",
      "regex": "(?mi)^\\s*ГАРАНТ:?\\s.*?(?=\\n{2,}|$)"
    },
    {
      "name": "Комментарии КонсультантПлюс",
      "regex": "(?mi)^\\s*(КонсультантПлюс|Документ предоставлен КонсультантПлюс).*?(?=\\n{2,}|$)"
    },
    {
      "name": "Обзор решений, справочные материалы",
      "regex": "(?mi)^\\s*См\\.\\s*(обзор|избранные материалы|аналит|материал|позиции высших судов|энциклопед|комментарии).*?(?=\\n{2,}|$)"
    },
    {
      "name": "Информация об изменениях",
      "regex": "(?mi)^\\s*Информация об изменениях:.*?(?=\\n{2,}|$)"
    },
    {
      "name": "Федеральные законы об изменениях",
      "regex": "(?mi)^\\s*Федеральным\\s+законом\\s+от\\s+\\d{1,2}\\s+[а-я]+\\s+\\d{4}\\s+г\\.\\s+N\\s*[\\d\\-ФЗ]+.*?(?=\\n{2,}|$)"
    },
    {
      "name": "См. предыдущую редакцию",
      "regex": "(?mi)^\\s*См\\.\\s*(текст|предыдущ|редакц).*?(?=\\n{2,}|$)"
    },
    {
      "name": "Постановления и правовые акты (вставки)",
      "regex": "(?mi)^\\s*О\\s+конституционно\\-правов.*?(?=\\n{2,}|$)"
    },
    {
      "name": "Система ГАРАНТ отметка страницы",
      "regex": "(?mi)^\\s*Система\\s+ГАРАНТ.*?(?=\\n{2,}|$)"
    },
    {
      "name": "Метаданные КонсультантПлюс (сайт, дата сохранения)",
      "regex": "(?mi)^(Дата\\s+сохранения:.*|www\\.consultant\\.ru|Документ предоставлен КонсультантПлюс).*"
    },
    {
      "name": "Примечание и приложения ГОСТ",
      "regex": "(?mi)^(Примечание\\.?|Рекомендуемое|Приложение\\s*\\d+).*"
    },
    {
      "name": "Печати и подписи на титульных листах ГОСТ",
      "regex": "(?mi)^(Печать|Личная\\s+подпись|Расшифровка\\s+подписи|Дата).*"
    },
    {
      "name": "Ссылки на обзоры и комментарии в кодексах",
      "regex": "(?mi)^\\s*См\\.\\s*(комментарии|обзор|позиции|материал).*?(?=\\n{2,}|$)"
    },
    {
      "name": "Ссылки на предыдущие редакции внутри текста",
      "regex": "(?mi)^\\s*См\\.\\s*текст\\s*(части|статьи).*?(предыдущ).*?(?=\\n{2,}|$)"
    },
    {
      "name": "Сноски о введении в действие закона",
      "regex": "(?mi)^\\s*См\\.\\s*Федеральный\\s+закон.*о введении в действие.*(?=\\n{2,}|$)"
    },
    {
      "name": "Системные отметки постраничной разбивки",
      "regex": "(?mi)^\\s*Страница\\s+\\d+\\s+из\\s+\\d+"
    }
  ]
}